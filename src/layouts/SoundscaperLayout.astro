---
import BrandSidebar from '../components/BrandSidebar.astro';
import { bundledCopyForLocale } from '../i18n/catalogs.js';
import { getLocaleDescriptor, localePath, ROUTE_LOCALES } from '../i18n/locales.js';
import { productLocalePath, productProfile } from '../lib/products.js';

interface Props {
	locale: string;
	embedded?: boolean;
	productId?: 'soundscaper' | 'framescaper';
}

const { locale, embedded = false, productId = 'soundscaper' } = Astro.props;
const localeDescriptor = getLocaleDescriptor(locale);
if (!localeDescriptor) throw new Error(`Unknown editor locale: ${locale}`);
const profile = productProfile(productId);
const title = profile.name;
const copy = bundledCopyForLocale(localeDescriptor.locale);
const description = productId === 'framescaper' ? copy.framescaperMetaDescription : copy.metaDescription;
const site = Astro.site ?? new URL('https://soundscaper.org');
const canonical = new URL(productLocalePath(productId, localeDescriptor.locale, { embedded }), site);
const alternateLocales = ROUTE_LOCALES.map((descriptor) => ({
	...descriptor,
	href: new URL(productLocalePath(productId, descriptor.locale, { embedded }), site),
}));
const xDefault = new URL(productLocalePath(productId, 'en', { embedded }), site);
---

<!doctype html>
<html lang={localeDescriptor.locale} dir={localeDescriptor.direction} data-embedded={embedded ? 'true' : undefined} data-product={productId}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light dark" />
		<meta name="description" content={description} />
		{productId === 'framescaper' ? (
			<link rel="icon" type="image/svg+xml" href="/logo/framescaper-icon.svg" />
		) : (
			<>
				<link rel="icon" type="image/svg+xml" href="/logo/logo-klein-schwarz.svg" media="(prefers-color-scheme: light)" />
				<link rel="icon" type="image/svg+xml" href="/logo/logo-klein-weiß.svg" media="(prefers-color-scheme: dark)" />
			</>
		)}
		<link rel="canonical" href={canonical} />
		{alternateLocales.map(({ locale: alternateLocale, href }) => <link rel="alternate" hreflang={alternateLocale} href={href} />)}
		<link rel="alternate" hreflang="x-default" href={xDefault} />
		<script>
			(() => {
				try {
					const productId = document.documentElement.dataset.product || 'soundscaper';
					localStorage.setItem('scape_last_active_product', productId);
					const stored = localStorage.getItem(`${productId}_theme`) || localStorage.getItem('soundscaper_theme');
					const theme = stored === 'light' || stored === 'dark' ? stored : matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
					document.documentElement.dataset.theme = theme;
					document.documentElement.style.colorScheme = theme;
				} catch {}
			})();
		</script>
		<title>{title}</title>
	</head>
	<body>
		<div class:list={['site-shell', { embedded }]}>
			{!embedded && <BrandSidebar locale={localeDescriptor.locale} productId={productId} />}
			<main><slot /></main>
		</div>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-text: #241913;
		--color-ink: #241913;
		--color-muted: #6f6258;
		--color-surface: #ffffff;
		--color-surface-raised: #ffffff;
		--color-surface-alt: #fff6ed;
		--color-control-surface: #ffffff;
		--color-line: #ead8c8;
		--color-accent: #ff6900;
		--color-accent-dark: #b84b00;
		--color-accent-soft: #fff1e4;
		--font-body: Ubuntu, Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}
	:root[data-theme='dark'] {
		color-scheme: dark;
		--color-text: #f8efe8;
		--color-ink: #f8efe8;
		--color-muted: #c3b3a8;
		--color-surface: #14100d;
		--color-surface-raised: #1b1511;
		--color-surface-alt: #241b16;
		--color-control-surface: #211813;
		--color-line: #47362c;
		--color-accent: #ff7a1a;
		--color-accent-dark: #ffb36b;
		--color-accent-soft: #3b2414;
	}
	* { box-sizing: border-box; }
	html, body { margin: 0; min-height: 100%; color: var(--color-ink); background: var(--color-surface); font-family: var(--font-body); line-height: 1.5; }
	.site-shell { display: grid; grid-template-columns: auto minmax(0, 1fr); min-height: 100vh; }
	.site-shell > main { min-width: 0; }
	.site-shell.embedded { display: block; }
	.container { width: min(1120px, calc(100% - 32px)); margin-inline: auto; }
	.tool-intro { padding-block: clamp(34px, 6vw, 68px); background: var(--color-surface-alt); border-bottom: 1px solid var(--color-line); }
	.tool-intro h1 { max-width: 780px; margin: 0; font-size: clamp(2.6rem, 7vw, 5.6rem); line-height: 0.96; }
	.tool-lede, .tool-note { max-width: 760px; margin: 18px 0 0; color: var(--color-muted); }
	.tool-note { font-size: 0.98rem; font-weight: 700; }
	.eyebrow { margin: 0 0 14px; color: var(--color-accent-dark); font-size: 0.8rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }
	.audio-editor-section { padding-block: 20px 48px; background: var(--color-surface-raised); }
	.audio-editor-timeline-scroll, [data-time-display] { direction: ltr; }
	:root[data-embedded='true'] .tool-intro { display: none; }
	:root[data-embedded='true'] .audio-editor-section { min-height: 100vh; padding-block: 0; }
	@media (max-width: 900px) { .site-shell { display: block; } }
</style>
