---
import AudioEditor from './tools/AudioEditor.astro';
import SoundscaperLayout from '../layouts/SoundscaperLayout.astro';

interface Props {
	locale: string;
	embedded?: boolean;
}

const { locale, embedded = false } = Astro.props;
---

<SoundscaperLayout locale={locale} embedded={embedded}>
	<AudioEditor locale={locale} />
</SoundscaperLayout>
