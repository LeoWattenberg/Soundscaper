---
import { DEFAULT_LOCALE_TAGS, getLocaleDescriptor, ROUTE_LOCALES } from '../i18n/locales.js';
import { bundledCopyForLocale } from '../i18n/catalogs.js';
import { localeLanguage } from '../i18n/locale.js';

interface Props {
	locale: string;
}

const { locale } = Astro.props;
const localeDescriptor = getLocaleDescriptor(locale);
if (!localeDescriptor) throw new Error(`Unknown Soundscaper locale: ${locale}`);
const chromeLocale = localeLanguage(localeDescriptor.locale) === 'de' ? 'de' : 'en';
const catalog = bundledCopyForLocale(localeDescriptor.locale);
const copy = {
	label: catalog.sidebarNavigation,
	editor: catalog.audioEditorLink,
	tools: catalog.moreToolsLink,
	guides: catalog.audacityGuidesLink,
	legal: catalog.legalLink,
	github: catalog.githubProjectLink,
	theme: catalog.themeToggle,
	light: catalog.lightTheme,
	dark: catalog.darkTheme,
	collapse: catalog.collapseNavigation,
	expand: catalog.expandNavigation,
	language: catalog.languageLabel,
	workspace: catalog.workspace,
	workspaceModern: catalog.workspaceModern,
	workspaceMusic: catalog.workspaceMusic,
	workspaceClassic: catalog.workspaceClassic,
	workspaceVideo: catalog.workspaceVideo,
	settings: catalog.sidebarSettings,
};
const routeLocales = ROUTE_LOCALES.map(({ locale: routeLocale, nativeName, direction }) => ({
	locale: routeLocale,
	name: nativeName,
	direction,
}));
const initialLocaleTags = new Set([...DEFAULT_LOCALE_TAGS, localeDescriptor.locale]);
const initialLocales = routeLocales.filter(({ locale: routeLocale }) => initialLocaleTags.has(routeLocale));
const translationsBaseUrl = import.meta.env.PUBLIC_TRANSLATIONS_BASE_URL
	|| 'https://translations.soundscaper.org/runtime/translations/audacity/4/';
---

<aside class="site-sidebar" data-sidebar data-locale={localeDescriptor.locale} data-translations-base-url={translationsBaseUrl} aria-label={copy.label}>
	<a class="brand" href={`/${locale}/`} aria-label={catalog.brandAccessibilityLabel}>
		<img class="logo-light logo-wide" src="/logo/logo-schwarz.svg" alt="kw.media" width="230" height="91" />
		<img class="logo-dark logo-wide" src="/logo/logo-weiß.svg" alt="kw.media" width="230" height="91" />
		<img class="logo-light logo-small" src="/logo/logo-klein-schwarz.svg" alt="" width="48" height="48" />
		<img class="logo-dark logo-small" src="/logo/logo-klein-weiß.svg" alt="" width="48" height="48" />
		<strong>Soundscaper</strong>
	</a>

	<button class="sidebar-collapse" type="button" data-sidebar-collapse data-collapse={copy.collapse} data-expand={copy.expand} aria-label={copy.collapse} aria-expanded="true">
		<span aria-hidden="true">‹</span>
	</button>

	<div class="sidebar-content" data-sidebar-content>
		<nav class="sidebar-nav" aria-label={copy.label}>
			<a class="sidebar-link is-active" href={`/${locale}/`} aria-current="page">{copy.editor}</a>
			<a class="sidebar-link" href={`https://kw.media/${chromeLocale}/tools/`}>{copy.tools}</a>
			<a class="sidebar-link" href={`https://kw.media/${chromeLocale}/audacity/`}>{copy.guides}</a>
			<a class="sidebar-link" href={`https://kw.media/${chromeLocale}/legal/`}>{copy.legal}</a>
			<a class="sidebar-link" href="https://github.com/LeoWattenberg/Soundscaper" target="_blank" rel="noreferrer">{copy.github}</a>
		</nav>

		<section class="sidebar-settings" aria-labelledby="sidebar-settings-title">
			<h2 id="sidebar-settings-title">{copy.settings}</h2>
			<label class="sidebar-workspace">
				<span>{copy.workspace}</span>
				<select data-workspace-select aria-label={copy.workspace} disabled>
					<option value="modern">{copy.workspaceModern}</option>
					<option value="music">{copy.workspaceMusic}</option>
					<option value="classic">{copy.workspaceClassic}</option>
					<option value="video-editor">{copy.workspaceVideo}</option>
				</select>
			</label>

			<div class="sidebar-actions">
				<button class="theme-toggle" type="button" data-theme-toggle data-light={copy.light} data-dark={copy.dark} aria-label={copy.theme} aria-pressed="false">
					<span class="theme-toggle-track" aria-hidden="true"><span class="theme-toggle-thumb"></span></span>
					<span data-theme-label>{copy.light}</span>
				</button>
				<label class="language-picker">
					<span>{copy.language}</span>
					<select data-locale-select aria-label={copy.language}>
						{initialLocales.map(({ locale: optionLocale, name }) => <option value={optionLocale} selected={optionLocale === localeDescriptor.locale}>{name}</option>)}
					</select>
				</label>
			</div>
		</section>
	</div>
	<script is:inline type="application/json" data-route-locales set:html={JSON.stringify(routeLocales)}></script>
</aside>

<script>
	const sidebar = document.querySelector<HTMLElement>('[data-sidebar]');
	const sidebarCollapse = document.querySelector<HTMLButtonElement>('[data-sidebar-collapse]');
	if (sidebar && sidebarCollapse) {
		const setSidebarCollapsed = (collapsed: boolean, persist = false) => {
			sidebar.dataset.collapsed = String(collapsed);
			sidebarCollapse.setAttribute('aria-expanded', String(!collapsed));
			sidebarCollapse.setAttribute('aria-label', collapsed ? sidebarCollapse.dataset.expand! : sidebarCollapse.dataset.collapse!);
			if (persist) localStorage.setItem('soundscaper_sidebar_collapsed', String(collapsed));
		};
		try {
			setSidebarCollapsed(localStorage.getItem('soundscaper_sidebar_collapsed') === 'true');
		} catch {}
		sidebarCollapse.addEventListener('click', () => setSidebarCollapsed(sidebar.dataset.collapsed !== 'true', true));
	}

	const toggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
	if (toggle) {
		const label = toggle.querySelector<HTMLElement>('[data-theme-label]');
		const sync = (theme: 'light' | 'dark') => {
			toggle.setAttribute('aria-pressed', String(theme === 'dark'));
			if (label) label.textContent = theme === 'dark' ? toggle.dataset.dark! : toggle.dataset.light!;
		};
		const apply = (theme: 'light' | 'dark') => {
			document.documentElement.dataset.theme = theme;
			document.documentElement.style.colorScheme = theme;
			localStorage.setItem('soundscaper_theme', theme);
			sync(theme);
		};
		sync(document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light');
		toggle.addEventListener('click', () => apply(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark'));
	}

	const workspaceSelect = sidebar?.querySelector<HTMLSelectElement>('[data-workspace-select]');
	if (workspaceSelect) {
		type WorkspaceState = {
			activeId?: string;
			workspaces?: Array<{ id?: string; name?: string }>;
		};
		window.addEventListener('soundscaper:workspace-state', (event) => {
			const detail = (event as CustomEvent<WorkspaceState>).detail;
			const workspaces = Array.isArray(detail?.workspaces) ? detail.workspaces : [];
			const options = workspaces
				.filter(({ id, name }) => typeof id === 'string' && id && typeof name === 'string' && name)
				.map(({ id, name }) => {
					const option = document.createElement('option');
					option.value = id!;
					option.textContent = name!;
					return option;
				});
			if (options.length) workspaceSelect.replaceChildren(...options);
			if (detail?.activeId && [...workspaceSelect.options].some(({ value }) => value === detail.activeId)) {
				workspaceSelect.value = detail.activeId;
			}
			workspaceSelect.disabled = false;
		});
		workspaceSelect.addEventListener('change', () => {
			window.dispatchEvent(new CustomEvent('soundscaper:workspace-request', {
				detail: { workspaceId: workspaceSelect.value },
			}));
		});
		window.dispatchEvent(new CustomEvent('soundscaper:workspace-ready'));
	}

	const localeSelect = sidebar?.querySelector<HTMLSelectElement>('[data-locale-select]');
	const routeLocalesElement = sidebar?.querySelector<HTMLScriptElement>('[data-route-locales]');
	if (sidebar && localeSelect && routeLocalesElement) {
		const currentLocale = sidebar.dataset.locale || 'en';
		let routeLocales: Array<{ locale: string; name: string; direction: 'ltr' | 'rtl' }> = [];
		try {
			routeLocales = JSON.parse(routeLocalesElement.textContent || '[]');
		} catch {}
		const routeLocaleByTag = new Map(routeLocales.map((descriptor) => [descriptor.locale, descriptor]));
		const renderOptions = (eligibleNames: Map<string, string>) => {
			const localeTags = new Set(['en', 'de', currentLocale, ...eligibleNames.keys()]);
			const descriptors = Array.from(localeTags, (tag) => routeLocaleByTag.get(tag)).filter(Boolean);
			descriptors.sort((left, right) => String(left?.name).localeCompare(String(right?.name), currentLocale));
			localeSelect.replaceChildren(...descriptors.map((descriptor) => {
				const option = document.createElement('option');
				option.value = descriptor?.locale || '';
				option.textContent = eligibleNames.get(option.value) || descriptor?.name || option.value;
				return option;
			}));
			localeSelect.value = localeTags.has(currentLocale) ? currentLocale : 'en';
		};
		localeSelect.addEventListener('change', () => {
			if (routeLocaleByTag.has(localeSelect.value)) window.location.assign(`/${localeSelect.value}/`);
		});
		const baseUrl = sidebar.dataset.translationsBaseUrl;
		if (baseUrl) {
			const controller = new AbortController();
			const timeout = window.setTimeout(() => controller.abort(), 5_000);
			fetch(`${baseUrl.replace(/\/+$/u, '')}/latest.json`, { cache: 'no-store', signal: controller.signal })
				.then((response) => {
					if (!response.ok) throw new Error(`Translation manifest request failed (${response.status})`);
					return response.json();
				})
				.then((manifest) => {
					const locales = manifest && typeof manifest.locales === 'object' && !Array.isArray(manifest.locales) ? manifest.locales : {};
					const eligibleNames = new Map<string, string>();
					for (const [tag, descriptor] of Object.entries<Record<string, unknown>>(locales)) {
						if (!routeLocaleByTag.has(tag) || !descriptor || typeof descriptor !== 'object' || descriptor.eligible !== true) continue;
						const name = typeof descriptor.name === 'string' && descriptor.name.trim() ? descriptor.name.trim() : routeLocaleByTag.get(tag)?.name || tag;
						eligibleNames.set(tag, name);
					}
					renderOptions(eligibleNames);
				})
				.catch(() => {})
				.finally(() => window.clearTimeout(timeout));
		}
	}
</script>

<style>
	.site-sidebar {
		position: sticky;
		top: 0;
		z-index: 20;
		display: flex;
		flex-direction: column;
		width: 260px;
		height: 100vh;
		padding: 28px 20px;
		background: var(--color-surface-raised);
		border-inline-end: 1px solid var(--color-line);
		transition: width 160ms ease, padding 160ms ease;
	}
	.brand { display: grid; gap: 8px; color: var(--color-ink); text-decoration: none; }
	.brand img { width: min(190px, 100%); height: auto; }
	.brand strong { color: var(--color-accent-dark); font-size: 1.05rem; letter-spacing: 0.02em; }
	.logo-dark, .logo-small { display: none; }
	:global(:root[data-theme='dark']) .logo-light { display: none; }
	:global(:root[data-theme='dark']) .logo-dark.logo-wide { display: block; }
	.sidebar-collapse {
		align-self: flex-end;
		width: 32px;
		height: 32px;
		margin-top: -32px;
		color: var(--color-muted);
		background: var(--color-control-surface);
		border: 1px solid var(--color-line);
		border-radius: 6px;
		font-size: 1.5rem;
		line-height: 1;
		cursor: pointer;
	}
	.sidebar-collapse:hover { color: var(--color-accent-dark); background: var(--color-surface-alt); }
	.sidebar-content { display: contents; }
	.sidebar-nav { display: grid; gap: 4px; margin-top: 34px; }
	.sidebar-link { padding: 10px 12px; color: var(--color-muted); border-radius: 6px; font-weight: 800; text-decoration: none; }
	.sidebar-link:hover, .sidebar-link.is-active { color: var(--color-accent-dark); background: var(--color-surface-alt); }
	.sidebar-settings {
		display: grid;
		gap: 8px;
		margin-top: auto;
		padding-top: 20px;
	}
	.sidebar-settings h2 {
		margin: 0 0 2px;
		color: var(--color-muted);
		font-size: 0.8rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.sidebar-workspace {
		display: grid;
		gap: 6px;
		color: var(--color-muted);
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
	.sidebar-workspace select {
		width: 100%;
		min-width: 0;
		min-height: 42px;
		padding: 8px 34px 8px 12px;
		color: var(--color-ink);
		background: var(--color-control-surface);
		border: 1px solid var(--color-line);
		border-radius: 6px;
		font: inherit;
		font-size: 0.92rem;
		font-weight: 800;
		letter-spacing: normal;
		text-transform: none;
	}
	.sidebar-workspace select:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}
	.sidebar-workspace select:disabled { opacity: 0.55; }
	.sidebar-actions { display: grid; gap: 8px; }
	.theme-toggle, .language-picker {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 42px;
		padding: 8px 12px;
		color: var(--color-ink);
		background: var(--color-control-surface);
		border: 1px solid var(--color-line);
		border-radius: 6px;
		font: inherit;
		font-weight: 800;
		cursor: pointer;
	}
	.language-picker { gap: 8px; cursor: default; }
	.language-picker select { min-width: 0; color: var(--color-ink); background: var(--color-surface-raised); border: 0; font: inherit; font-weight: 800; }
	.theme-toggle-track { display: inline-flex; width: 38px; height: 22px; padding: 3px; background: var(--color-surface-alt); border: 1px solid var(--color-line); border-radius: 999px; }
	.theme-toggle-thumb { width: 14px; height: 14px; background: var(--color-accent); border-radius: 50%; transition: transform 160ms ease; }
	.theme-toggle[aria-pressed='true'] .theme-toggle-thumb { transform: translateX(16px); }
	:global(:root[dir='rtl']) .sidebar-collapse span { display: block; transform: scaleX(-1); }
	:global(:root[dir='rtl']) .theme-toggle[aria-pressed='true'] .theme-toggle-thumb { transform: translateX(-16px); }
	.site-sidebar[data-collapsed='true'] { width: 72px; padding: 20px 12px; align-items: center; }
	.site-sidebar[data-collapsed='true'] .brand { align-items: center; }
	.site-sidebar[data-collapsed='true'] .logo-wide,
	.site-sidebar[data-collapsed='true'] .brand strong { display: none; }
	.site-sidebar[data-collapsed='true'] .logo-light.logo-small { display: block; width: 42px; }
	:global(:root[data-theme='dark']) .site-sidebar[data-collapsed='true'] .logo-light.logo-small { display: none; }
	:global(:root[data-theme='dark']) .site-sidebar[data-collapsed='true'] .logo-dark.logo-small { display: block; width: 42px; }
	.site-sidebar[data-collapsed='true'] .sidebar-collapse { align-self: center; margin-top: 16px; }
	.site-sidebar[data-collapsed='true'] .sidebar-collapse span { display: block; transform: rotate(180deg); }
	:global(:root[dir='rtl']) .site-sidebar[data-collapsed='true'] .sidebar-collapse span { transform: rotate(180deg) scaleX(-1); }
	.site-sidebar[data-collapsed='true'] .sidebar-content { display: none; }
	@media (max-width: 900px) {
		.site-sidebar { position: relative; width: 100%; height: auto; padding: 14px 16px; border-inline-end: 0; border-bottom: 1px solid var(--color-line); }
		.site-sidebar[data-collapsed='true'] { width: 100%; padding: 14px 16px; align-items: stretch; }
		.sidebar-collapse { display: none; }
		.site-sidebar[data-collapsed='true'] .sidebar-content { display: contents; }
		.brand { grid-template-columns: auto 1fr; align-items: center; }
		.brand .logo-wide { display: none !important; }
		.brand .logo-light.logo-small { display: block; width: 42px; }
		:global(:root[data-theme='dark']) .brand .logo-light.logo-small { display: none; }
		:global(:root[data-theme='dark']) .brand .logo-dark.logo-small { display: block; width: 42px; }
		.sidebar-nav { display: flex; gap: 6px; margin-top: 12px; overflow-x: auto; }
		.sidebar-link { flex: 0 0 auto; }
		.sidebar-settings { margin-top: 12px; padding-top: 0; }
		.sidebar-actions { grid-template-columns: 1fr 1fr; }
	}
</style>
