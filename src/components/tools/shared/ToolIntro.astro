---
interface Props {
	eyebrow: string;
	title: string;
	intro: string;
	note?: string;
}

const { eyebrow, title, intro, note } = Astro.props;
---

<section class="tool-intro">
	<div class="container">
		<p class="eyebrow">{eyebrow}</p>
		<h1>{title}</h1>
		<p class="tool-lede">{intro}</p>
		{note && <p class="tool-note">{note}</p>}
	</div>
</section>
