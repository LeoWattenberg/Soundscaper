---
import type { Locale } from '../../i18n';
import { bundledCopyForLocale } from '../../i18n/catalogs.js';
import AudioEditorBootstrap from './audio-editor/AudioEditorBootstrap.jsx';
import ToolIntro from './shared/ToolIntro.astro';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const copy = bundledCopyForLocale(locale);
---

<ToolIntro eyebrow={copy.eyebrow} title={copy.title} intro={copy.intro} note={copy.privacy} />

<section class="section audio-editor-section tool-workspace">
	<div class="container audio-editor-container">
		<AudioEditorBootstrap client:only="react" locale={locale} fallbackCopy={copy}>
			<div slot="fallback" role="status" aria-live="polite">{copy.loading}</div>
		</AudioEditorBootstrap>
	</div>
</section>
