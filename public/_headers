/*
	Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://assets.soundscaper.org; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https://kw.media; media-src 'self' blob:; worker-src 'self' blob:; connect-src 'self' https://assets.soundscaper.org https://translations.soundscaper.org; object-src 'none'; base-uri 'self'; frame-ancestors 'self' https://kw.media
	Cross-Origin-Opener-Policy: same-origin
	Cross-Origin-Embedder-Policy: credentialless
	Referrer-Policy: strict-origin-when-cross-origin
	Permissions-Policy: microphone=(self), speaker-selection=(self), display-capture=(self), camera=(), geolocation=()
	X-Content-Type-Options: nosniff

/_astro/*
	Cache-Control: public, max-age=31536000, immutable
