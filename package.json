{
	"name": "soundscaper",
	"version": "0.2.0-beta.1",
	"description": "A local-first multitrack audio editor for the web and desktop.",
	"private": true,
	"type": "module",
	"main": "desktop/main.mjs",
	"author": "kw.media",
	"homepage": "https://soundscaper.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/LeoWattenberg/Soundscaper.git"
	},
	"license": "AGPL-3.0-only",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && node scripts/check-i18n-build.mjs && node scripts/check-cloudflare-assets.mjs",
		"preview": "astro preview",
		"test": "node --test",
		"test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/lib/tools/**/*.js' --test-coverage-lines=80 --test-coverage-branches=70 --test-coverage-functions=80 tests/*.test.js",
		"pretest:browser": "npm run build",
		"test:browser": "playwright test",
		"test:desktop": "node --test tests/desktop-*.test.js tests/audio-editor-file-service.test.js",
		"desktop:icons": "node scripts/desktop-icons.mjs",
		"desktop:prepare": "node scripts/desktop-prepare.mjs",
		"desktop:dev": "npm run desktop:prepare && electron .",
		"desktop:dir": "npm run desktop:prepare && electron-builder --config electron-builder.config.cjs --dir",
		"desktop:dist": "npm run desktop:prepare && electron-builder --config electron-builder.config.cjs --publish never",
		"desktop:smoke": "node scripts/desktop-smoke.mjs",
		"desktop:release-assets": "node scripts/desktop-release-assets.mjs",
		"postinstall": "node scripts/apply-component-patches.mjs && patch-package --patch-dir patches/npm",
		"build:staffpad": "node scripts/build-staffpad-wasm.mjs",
		"audit:staffpad": "node scripts/audit-staffpad-wasm.mjs",
		"build:nyquist": "node scripts/build-nyquist-wasm.mjs",
		"audit:nyquist": "node scripts/audit-nyquist-wasm.mjs",
		"build:parametric-eq": "node scripts/build-parametric-eq-wasm.mjs",
		"audit:parametric-eq": "node scripts/audit-parametric-eq-wasm.mjs",
		"audit:aup4-interop": "node scripts/audit-aup4-interop.mjs",
		"audit:aup4-interop:release": "node scripts/audit-aup4-interop.mjs --require-native",
		"audit:ebu-r128": "node scripts/audit-ebu-r128.mjs",
		"deploy": "npm run build && npx --yes wrangler@4 pages deploy dist --project-name soundscaper",
		"deploy:runtime": "node scripts/publish-runtime-assets.mjs"
	},
	"dependencies": {
		"@astrojs/react": "6.0.1",
		"@dilsonspickles/components": "0.9.0",
		"@ffmpeg/core": "0.12.10",
		"@ffmpeg/ffmpeg": "0.12.15",
		"@sqlite.org/sqlite-wasm": "3.53.0-build1",
		"astro": "^7.1.1",
		"fflate": "0.8.3",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"sql.js": "1.14.1"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@electron/fuses": "2.1.3",
		"@playwright/test": "^1.61.1",
		"@resvg/resvg-js": "2.6.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"electron": "43.1.1",
		"electron-builder": "26.15.6",
		"patch-package": "^8.0.1",
		"postcss": "8.5.19",
		"saxes": "6.0.0"
	},
	"overrides": {
		"@electron/asar": "4.2.0",
		"@electron/get": "5.0.0",
		"electron-winstaller": "5.4.4",
		"glob": "13.0.6",
		"rimraf": "6.1.3"
	}
}
